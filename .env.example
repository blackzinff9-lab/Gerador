# ENGAJAÍ — Variáveis de ambiente
# Copie este arquivo para .env.local e preencha com as suas chaves reais.
# NUNCA commite o .env.local — ele já está no .gitignore.

# Gemini (Google AI Studio) — pegue em: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# YouTube Data API v3 — pegue em: https://console.cloud.google.com
#  1. Crie um projeto novo (ex: "ENGAJAI")
#  2. Em "APIs & Services", habilite "YouTube Data API v3"
#  3. Em "Credentials", crie uma "API key" e (recomendado) restrinja à API acima
YOUTUBE_API_KEY=
