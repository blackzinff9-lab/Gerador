# ENGAJAÍ — Variáveis de ambiente
# Copie este arquivo para .env.local e preencha com as suas chaves reais.
# NUNCA commite o .env.local — ele já está no .gitignore.

# Gemini (Google AI Studio) — pegue em: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# YouTube Data API v3 — pegue em: https://console.cloud.google.com
#  1. Crie um projeto novo (ex: "ENGAJAI")
#  2. Em "APIs & Services", habilite "YouTube Data API v3"
#  3. Em "Credentials", crie uma "API key" e (recomendado) restrinja à API acima
YOUTUBE_API_KEY=

# ─── Login com Google (NextAuth) ────────────────────────────────────────────
# O ENGAJAÍ usa NextAuth.js com provedor Google OAuth. Sessão em JWT (sem DB).

# Segredo usado pra assinar os JWTs da sessão.
# Gere um valor aleatório seguro: `openssl rand -base64 32`
# Qualquer string aleatória longa funciona. MUDE em produção — não use este exemplo.
NEXTAUTH_SECRET=

# URL pública do app. Em dev: http://localhost:3000
# Em produção: o Vercel injeta automaticamente VERCEL_URL, mas é mais previsível
# configurar manualmente com a URL final (ex.: https://engajai.vercel.app).
NEXTAUTH_URL=http://localhost:3000

# Credenciais OAuth do Google. Como pegar:
#  1. https://console.cloud.google.com → seu projeto (mesmo que você usa no YouTube API).
#  2. "APIs & Services" → "OAuth consent screen": configure como "External",
#     preencha nome do app, email de suporte, domínio (adicione o domínio do Vercel
#     em "Authorized domains") e salve.
#  3. "Credentials" → "Create Credentials" → "OAuth client ID":
#       • Application type: "Web application"
#       • Name: "ENGAJAI"
#       • Authorized JavaScript origins:
#           http://localhost:3000
#           https://SEU-APP.vercel.app
#       • Authorized redirect URIs:
#           http://localhost:3000/api/auth/callback/google
#           https://SEU-APP.vercel.app/api/auth/callback/google
#  4. Copie Client ID e Client Secret pra cá.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
